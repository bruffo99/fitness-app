generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum ProspectStatus {
  NEW_LEAD
  CONTACTED
  QUALIFIED
  CLIENT_ACTIVE
  INACTIVE
  ARCHIVED
}

enum TargetType {
  WEIGHT
  BODY_FAT
  PERFORMANCE
  HABIT
  OTHER
}

model Prospect {
  id               String         @id @default(cuid())
  firstName        String
  lastName         String
  email            String
  phone            String?
  goalSummary      String
  goalType         String?
  fitnessLevel     String?
  timeline         String?
  injuries         String?
  preferredContact String?
  referralSource   String?
  message          String?
  followUpDate     DateTime?
  notes            ProspectNote[]
  source           String?
  status           ProspectStatus @default(NEW_LEAD)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([email])
  @@index([status])
  @@index([followUpDate])
}

model ProspectNote {
  id         String   @id @default(cuid())
  prospectId String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId, createdAt])
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  role           UserRole         @default(CLIENT)
  firstName      String?
  lastName       String?
  phone          String?
  isActive       Boolean          @default(true)
  lastLoginAt    DateTime?
  passwordHash   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  adminSessions  AdminSession[]
  checkIns       CheckIn[]
  documents      ClientDocument[]
  gymPhotos      GymPhoto[]
  magicLinks     MagicLinkToken[]
  clientProfile  ClientProfile?
}

model CheckIn {
  id             String   @id @default(cuid())
  userId         String
  weekOf         DateTime
  bodyWeight     Float?
  bodyFat        Float?
  energyLevel    Int?
  sleepQuality   Int?
  adherence      Int?
  trainingNotes  String?
  nutritionNotes String?
  wins           String?
  struggles      String?
  coachNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekOf])
  @@index([userId])
  @@index([weekOf])
}

model ClientDocument {
  id        String   @id @default(cuid())
  userId     String
  title      String
  category   String
  content    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([isActive])
}

model GymPhoto {
  id        String   @id @default(cuid())
  userId    String
  filePath  String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AdminSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  userId     String?
  email      String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

model ClientProfile {
  id                String         @id @default(cuid())
  userId            String         @unique
  fullName          String?
  onboardingStatus  String         @default("draft")
  requiredSessionsPerWeek Int      @default(3)
  trainingHistory   String?
  nutritionNotes    String?
  injuryNotes       String?
  primaryGoal       String?
  motivation        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets           ClientTarget[]
}

model ClientTarget {
  id              String        @id @default(cuid())
  clientProfileId String
  type            TargetType    @default(OTHER)
  label           String
  targetValue     String?
  targetDate      DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId])
  @@index([type])
  @@index([isActive])
}
